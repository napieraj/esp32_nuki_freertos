#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VENV_DIR="${REPO_ROOT}/.venv"
ESPHOME_REF="${ESPHOME_REF:-dev}"
ESPHOME_PREWARM_COMPILE="${ESPHOME_PREWARM_COMPILE:-1}"
ESPHOME_PREWARM_CONFIG="${ESPHOME_PREWARM_CONFIG:-nuki-lock-test.yaml}"

info()  { printf '\033[1;34m==> %s\033[0m\n' "$*"; }
ok()    { printf '\033[1;32m==> %s\033[0m\n' "$*"; }
warn()  { printf '\033[1;33m==> %s\033[0m\n' "$*"; }
fail()  { printf '\033[1;31m==> %s\033[0m\n' "$*" >&2; exit 1; }

# ── Pre-flight checks ────────────────────────────────────────────────────────

info "Checking prerequisites..."

python3 --version >/dev/null 2>&1 || fail "python3 not found. Install Python 3.12+."

PYTHON_MINOR=$(python3 -c 'import sys; print(sys.version_info.minor)')
if [ "$PYTHON_MINOR" -lt 12 ]; then
    fail "Python 3.12+ required (found 3.${PYTHON_MINOR})."
fi

if ! command -v clang-format >/dev/null 2>&1; then
    warn "clang-format not found — C++ formatting will be unavailable."
    warn "  macOS:  brew install clang-format"
    warn "  Ubuntu: sudo apt-get install clang-format"
fi

# ── Virtual environment ───────────────────────────────────────────────────────

if [ ! -d "$VENV_DIR" ]; then
    info "Creating virtual environment at ${VENV_DIR}..."
    python3 -m venv "$VENV_DIR"
else
    info "Virtual environment already exists at ${VENV_DIR}."
fi

# shellcheck disable=SC1091
source "${VENV_DIR}/bin/activate"

info "Upgrading pip..."
pip install --upgrade pip --quiet

# ── ESPHome (dev branch) + linters ────────────────────────────────────────────

info "Installing ESPHome (${ESPHOME_REF} branch) and dev tools..."
pip install \
    "esphome @ git+https://github.com/esphome/esphome.git@${ESPHOME_REF}" \
    ruff \
    --quiet

# ── Verify installation ──────────────────────────────────────────────────────

info "Verifying installation..."
esphome version
ruff version

# ── Validate config ──────────────────────────────────────────────────────────

info "Validating ESPHome config..."
cd "$REPO_ROOT"
esphome config "$ESPHOME_PREWARM_CONFIG" >/dev/null

if [ "$ESPHOME_PREWARM_COMPILE" = "1" ]; then
    info "Prewarming PlatformIO/ESP-IDF toolchain via compile..."
    info "This is expected to take ~60s on first run."
    esphome compile "$ESPHOME_PREWARM_CONFIG" >/dev/null
else
    warn "Skipping compile prewarm (ESPHOME_PREWARM_COMPILE=${ESPHOME_PREWARM_COMPILE})."
fi

ok "Setup complete!"
echo ""
echo "  Activate the venv:  source .venv/bin/activate"
echo "  Validate config:    make config"
echo "  Compile firmware:   make compile"
echo "  Lint all:           make lint"
echo "  See all targets:    make help"
echo ""
echo "  Setup now prewarms the ESP32-S3 toolchain by default."
echo "  Disable prewarm:    ESPHOME_PREWARM_COMPILE=0 make setup"
